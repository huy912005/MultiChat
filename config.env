# ============================================
# Configuration cho Chat App Deployment
# ============================================

# --- LOCAL DEVELOPMENT ---
CHAT_ENV=local
CHAT_DB_HOST=127.0.0.1
CHAT_DB_PORT=3306
CHAT_DB_NAME=ChatAppDB
CHAT_DB_USER=root
CHAT_DB_PASS=root
CHAT_SERVER_HOST=localhost
CHAT_SERVER_PORT=5000
CHAT_SERVER_HEADLESS=false

# --- GOOGLE CLOUD VM DEPLOYMENT ---
# CHAT_ENV=cloud_vm
# CHAT_DB_HOST=YOUR-CLOUD-SQL-IP
# CHAT_DB_PORT=3306
# CHAT_DB_NAME=ChatAppDB
# CHAT_DB_USER=chatuser
# CHAT_DB_PASS=YourSecurePassword123!
# CHAT_SERVER_HOST=0.0.0.0
# CHAT_SERVER_PORT=5000
# CHAT_SERVER_HEADLESS=true

# --- CLIENT CONFIGURATION ---
# Thay YOUR-EXTERNAL-IP bằng IP thực khi deploy
CLIENT_SERVER_HOST=localhost
CLIENT_SERVER_PORT=5000
